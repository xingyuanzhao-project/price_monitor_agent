# Copy to .env and fill in your keys. The .env file is gitignored.

# LLM provider API keys (at least one required for workflow execution)
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local model server endpoints (optional — set if running local models)
OLLAMA_API_BASE=http://localhost:11434/v1
VLLM_API_BASE=http://localhost:8001/v1
LLAMA_CPP_API_BASE=http://localhost:8080/v1

# Server configuration (optional — defaults shown)
PRICE_MONITOR_HOST=0.0.0.0
PRICE_MONITOR_PORT=8000
PRICE_MONITOR_CORS_ORIGINS=["http://localhost:5173","http://localhost:8000"]
PRICE_MONITOR_LOG_LEVEL=INFO
